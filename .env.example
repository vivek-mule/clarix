# ============================================================
#  AI-Powered Adaptive Learning Platform — Environment Variables
#  Copy this file to '.env' and fill in your actual credentials.
#  NEVER commit the real .env file to version control.
# ============================================================

# ── Google Vertex AI (Gemini LLM) ───────────────────────────
# Authenticate via: gcloud auth application-default login
# Project ID from Google Cloud Console
GCP_PROJECT_ID=your_gcp_project_id_here
# Region (us-central1 has best Gemini availability)
GCP_LOCATION=us-central1

# ── Pinecone (Vector Database) ──────────────────────────────
# Obtain from https://app.pinecone.io  →  API Keys
PINECONE_API_KEY=your_pinecone_api_key_here
# The cloud environment for your Pinecone project (e.g. "us-east-1")
PINECONE_ENVIRONMENT=us-east-1
# Name of the Pinecone index (dimension=384, metric=cosine)
PINECONE_INDEX_NAME=adaptive-learning

# ── Supabase (Auth + PostgreSQL) ────────────────────────────
# Obtain from https://supabase.com  →  Project Settings  →  API
# The project URL (e.g. https://xyzcompany.supabase.co)
SUPABASE_URL=https://your-project-id.supabase.co
# Public anonymous key — safe for client-side use
SUPABASE_ANON_KEY=your_supabase_anon_key_here
# Service-role key — server-side only, NEVER expose to clients
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
# JWT secret — used to verify Supabase access tokens server-side
# Found at Supabase → Project Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# ── Backend Server ──────────────────────────────────────────
# Host and port for the FastAPI dev server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Comma-separated origins allowed by CORS (React dev server)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Frontend ────────────────────────────────────────────────
# The URL the React app uses to reach the backend API
VITE_API_BASE_URL=http://localhost:8000
# Supabase credentials forwarded to the browser
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
